

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Farm{
  id Int @id @default(autoincrement())
  name String
  location String
  plots Plot[]

  createdAt DateTime @default(now())
}

model Plot{
  id Int @id @default(autoincrement())
  cropTtype String
  areaInHecares Float
  farmId Int
  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
